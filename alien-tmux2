#!/usr/bin/env bash

SESSION="conky-by-code"
PANES_PER_WINDOW=4

# --- Resolve base directory of this script ---
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- Code → "dir|rcfile" map (single source of truth) ---
declare -A MAP

MAP[a]="arc|arc.rc"
MAP[hc]="calendar|hcal.rc"
MAP[h2]="calendar|hcal2.rc"
MAP[lc]="calendar|lcalendar.rc"
MAP[kc]="calendar|kcalendar.rc"
MAP[sc]="calendar|sidepanel-calendar.rc"
MAP[s]="calendar|sys-small.rc"
MAP[t]="clock|clock.rc"
MAP[m]="clock|song-info.rc"
MAP[e]="earth|earth.rc"
MAP[g]="gcal|gcal.rc"
MAP[r]="rss|rss2.rc"
MAP[$]="stocks|ticker.rc"
MAP[v]="vnstat|vnstat.rc"
MAP[wc]="weather|current.rc"
MAP[wf]="weather|forecast.rc"
MAP[wa]="weather|full.rc"
MAP[asf]="~/.conky/rew62/system|system.rc"
MAP[anf]="~/.conky/rew62/network|network.rc"

# --- Input check ---
if [ "$#" -eq 0 ]; then
    echo "Usage: $(basename "$0") [codes...]"
    echo ""
    echo "  Codes:"
    echo "    a           arc"
    echo "    t           clock"
    echo "    m           song info"
    echo "    e           earth"
    echo "    g           gcal"
    echo "    r           rss"
    echo "    \$           stocks"
    echo "    v           vnstat"
    echo "    hc          calendar  (hcal)"
    echo "    h2          calendar  (hcal2)"
    echo "    lc          calendar  (lcalendar)"
    echo "    kc          calendar  (kcalendar)"
    echo "    sc          calendar  (sidepanel)"
    echo "    s           sys-small"
    echo "    wc          weather   (current)"
    echo "    wf          weather   (forecast)"
    echo "    wa          weather   (full)"
    echo ""
    echo "  Example: $(basename "$0") t wc wf a"
    exit 1
fi

# --- Optional bracket parsing ---
if [[ "$1" =~ ^\[.*\]$ ]]; then
    args=$(echo "$1" | tr -d '[]' | tr ',' ' ')
    set -- $args
fi

# --- Remove duplicates ---
declare -A SEEN
FILTERED=()

for code in "$@"; do
    if [[ -z "${SEEN[$code]}" ]]; then
        SEEN[$code]=1
        FILTERED+=("$code")
    fi
done

# --- Initialize window/pane counters, joining existing session if present ---
if tmux has-session -t "$SESSION" 2>/dev/null; then
    win=$(( $(tmux list-windows -t "$SESSION" | wc -l) - 1 ))
    last_panes=$(tmux list-panes -t "$SESSION:$win" | wc -l)
    pane=$(( win * PANES_PER_WINDOW + last_panes ))
else
    win=0
    pane=0
fi

for code in "${FILTERED[@]}"; do

    entry="${MAP[$code]}"

    # --- Ignore invalid codes ---
    if [ -z "$entry" ]; then
        echo "Skipping unknown code: $code"
        continue
    fi

    dir="${entry%%|*}"
    rc="${entry##*|}"

    if [[ "$dir" = ~* ]]; then
        full_dir="${dir/#\~/$HOME}"
    elif [[ "$dir" = /* ]]; then
        full_dir="$dir"
    else
        full_dir="$BASE_DIR/$dir"
    fi
    full_rc="$full_dir/$rc"

    # --- Validation checks ---
    if [ ! -d "$full_dir" ]; then
        echo "Skipping $code → directory not found: $full_dir"
        continue
    fi

    if [ ! -f "$full_rc" ]; then
        echo "Skipping $code → rc file not found: $full_rc"
        continue
    fi

    # --- Skip if already running ---
    if pgrep -f "conky -c $rc" > /dev/null 2>&1; then
        echo "Skipping $code → already running (conky -c $rc)"
        continue
    fi

    cmd="conky -c $rc"

    # --- New window every N panes ---
    if (( pane % PANES_PER_WINDOW == 0 )); then
        if (( pane == 0 )); then
            tmux new-session -d -s "$SESSION" -n "Conky-1" -c "$full_dir"
        else
            ((win++))
            tmux new-window -t "$SESSION:$win" -n "Conky-$((win+1))" -c "$full_dir"
        fi
        tmux send-keys -t "$SESSION:$win.0" "$cmd" C-m
    else
        tmux split-window -t "$SESSION:$win" -c "$full_dir"
        tmux select-layout -t "$SESSION:$win" tiled
        tmux send-keys -t "$SESSION:$win" "$cmd" C-m
    fi

    ((pane++))
done

# --- Bail if nothing valid was launched ---
if (( pane == 0 )); then
    echo "No valid codes provided. Nothing started."
    exit 1
fi

# --- Final layout cleanup ---
for ((i=0; i<=win; i++)); do
    tmux select-layout -t "$SESSION:$i" tiled
done

tmux attach-session -t "$SESSION"
